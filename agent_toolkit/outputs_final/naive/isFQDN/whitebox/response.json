{
  "obligations": [],
  "test_groups": [
    {
      "title": "Default options",
      "validator": "isFQDN",
      "args": [{}],
      "valid": [
        "example.com",
        "sub.domain.com",
        "xn--example.com"
      ],
      "invalid": [
        "example",
        "example.",
        "example..com",
        "example_com",
        "123",
        "example.123",
        "example.-com",
        "-example.com",
        "example.com-",
        "example.com ",
        "example.com\u0001"
      ],
      "rationale": "Tests the default behavior of isFQDN with common valid and invalid cases."
    },
    {
      "title": "require_tld: false",
      "validator": "isFQDN",
      "args": [{ "require_tld": false }],
      "valid": [
        "example",
        "example.com",
        "sub.domain"
      ],
      "invalid": [
        "example.",
        "example..",
        "example..com",
        "example_com",
        "example.-com",
        "-example.com",
        "example.com-",
        "example.com ",
        "example.com\u0001"
      ],
      "rationale": "Tests behavior when TLD is not required."
    },
    {
      "title": "allow_underscores: true",
      "validator": "isFQDN",
      "args": [{ "allow_underscores": true }],
      "valid": [
        "example_com",
        "sub_domain.example.com"
      ],
      "invalid": [
        "example..com",
        "example.-com",
        "-example.com",
        "example.com-",
        "example.com ",
        "example.com\u0001"
      ],
      "rationale": "Tests behavior when underscores are allowed in domain parts."
    },
    {
      "title": "allow_trailing_dot: true",
      "validator": "isFQDN",
      "args": [{ "allow_trailing_dot": true }],
      "valid": [
        "example.com.",
        "sub.domain.com."
      ],
      "invalid": [
        "example..com.",
        "example.-com.",
        "-example.com.",
        "example.com-.",
        "example.com .",
        "example.com\u0001."
      ],
      "rationale": "Tests behavior when trailing dots are allowed."
    },
    {
      "title": "allow_numeric_tld: true",
      "validator": "isFQDN",
      "args": [{ "allow_numeric_tld": true }],
      "valid": [
        "example.123",
        "sub.domain.456"
      ],
      "invalid": [
        "example..com",
        "example.-com",
        "-example.com",
        "example.com-",
        "example.com ",
        "example.com\u0001"
      ],
      "rationale": "Tests behavior when numeric TLDs are allowed."
    },
    {
      "title": "allow_wildcard: true",
      "validator": "isFQDN",
      "args": [{ "allow_wildcard": true }],
      "valid": [
        "*.example.com",
        "*.sub.domain.com"
      ],
      "invalid": [
        "*example.com",
        "example.*.com",
        "*.example..com",
        "*.example.-com",
        "*-example.com",
        "*.example.com-",
        "*.example.com ",
        "*.example.com\u0001"
      ],
      "rationale": "Tests behavior when wildcard domains are allowed."
    }
  ]
}