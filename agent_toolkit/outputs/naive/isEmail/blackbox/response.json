{
  "obligations": [],
  "test_groups": [
    {
      "title": "Default options",
      "validator": "isEmail",
      "args": [{}],
      "valid": [
        "test@example.com",
        "user.name+tag+sorting@example.com",
        "x@example.com",
        "example-indeed@strange-example.com"
      ],
      "invalid": [
        "plainaddress",
        "@missingusername.com",
        "username@.com",
        "username@com",
        "username@domain..com"
      ],
      "error": [
        12345,
        null,
        true,
        [],
        {}
      ],
      "rationale": "Validates basic email format with default options.",
      "obligations": []
    },
    {
      "title": "Allow display name",
      "validator": "isEmail",
      "args": [{ "allow_display_name": true }],
      "valid": [
        "Display Name <test@example.com>",
        "User <user.name+tag+sorting@example.com>"
      ],
      "invalid": [
        "Display Name test@example.com",
        "User user.name+tag+sorting@example.com"
      ],
      "error": [
        12345,
        null,
        true,
        [],
        {}
      ],
      "rationale": "Allows email format with display name when enabled.",
      "obligations": []
    },
    {
      "title": "Require display name",
      "validator": "isEmail",
      "args": [{ "require_display_name": true }],
      "valid": [
        "Display Name <test@example.com>",
        "User <user.name+tag+sorting@example.com>"
      ],
      "invalid": [
        "test@example.com",
        "user.name+tag+sorting@example.com"
      ],
      "error": [
        12345,
        null,
        true,
        [],
        {}
      ],
      "rationale": "Requires display name format when enabled.",
      "obligations": []
    },
    {
      "title": "Allow IP domain",
      "validator": "isEmail",
      "args": [{ "allow_ip_domain": true }],
      "valid": [
        "test@[123.123.123.123]",
        "user@[2001:db8::ff00:42:8329]"
      ],
      "invalid": [
        "test@123.123.123.123",
        "user@2001:db8::ff00:42:8329"
      ],
      "error": [
        12345,
        null,
        true,
        [],
        {}
      ],
      "rationale": "Allows IP addresses in the domain part when enabled.",
      "obligations": []
    },
    {
      "title": "Disallow UTF8 local part",
      "validator": "isEmail",
      "args": [{ "allow_utf8_local_part": false }],
      "valid": [
        "test@example.com",
        "user.name+tag+sorting@example.com"
      ],
      "invalid": [
        "üser@example.com",
        "测试@例子.广告"
      ],
      "error": [
        12345,
        null,
        true,
        [],
        {}
      ],
      "rationale": "Disallows non-English UTF8 characters in the local part when disabled.",
      "obligations": []
    },
    {
      "title": "Require TLD",
      "validator": "isEmail",
      "args": [{ "require_tld": true }],
      "valid": [
        "test@example.com",
        "user.name+tag+sorting@example.com"
      ],
      "invalid": [
        "test@localhost",
        "user@domain"
      ],
      "error": [
        12345,
        null,
        true,
        [],
        {}
      ],
      "rationale": "Requires a top-level domain in the email address when enabled.",
      "obligations": []
    },
    {
      "title": "Blacklist specific characters",
      "validator": "isEmail",
      "args": [{ "blacklisted_chars": "!" }],
      "valid": [
        "test@example.com",
        "user.name+tag+sorting@example.com"
      ],
      "invalid": [
        "test!@example.com",
        "user!name@example.com"
      ],
      "error": [
        12345,
        null,
        true,
        [],
        {}
      ],
      "rationale": "Rejects emails containing blacklisted characters in the local part.",
      "obligations": []
    },
    {
      "title": "Host blacklist",
      "validator": "isEmail",
      "args": [{ "host_blacklist": ["example.com", "blacklisted.com"] }],
      "valid": [
        "test@allowed.com",
        "user@permitted.com"
      ],
      "invalid": [
        "test@example.com",
        "user@blacklisted.com"
      ],
      "error": [
        12345,
        null,
        true,
        [],
        {}
      ],
      "rationale": "Rejects emails with domains in the host blacklist.",
      "obligations": []
    }
  ]
}